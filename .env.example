# Credenciais do Supabase.
# Copie este arquivo para .env e preencha com os valores do seu projeto.
# Disponíveis em: Supabase > Project Settings > API

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_KEY=sua-anon-key-publica

# Monitoramento de erros (opcional — Sentry)
# Crie um projeto em https://sentry.io e cole o DSN abaixo.
# Deixe em branco para desativar.
VITE_SENTRY_DSN=

# Ambiente atual: development | staging | production
VITE_APP_ENV=development
